# ── OpenSky Network (flight data) ────────────────────────────────────────────
# Free account at https://opensky-network.org
OPENSKY_CLIENT_ID=your_opensky_email_or_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret

# ── Windy Webcams API ─────────────────────────────────────────────────────────
# Free key at https://api.windy.com
WINDY_API_KEY=your_windy_api_key

# ── NASA FIRMS (wildfire data) ────────────────────────────────────────────────
# Free MAP_KEY at https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=your_firms_map_key

# ── AISStream (ship tracking) ─────────────────────────────────────────────────
# Free API key at https://aisstream.io
AIS_API_KEY=your_aisstream_api_key
